rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function userDocExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return userDocExists() && userDoc().role == "admin";
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ===== SETTINGS (Google Drive, Integrations, etc.) =====
    match /settings/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== PROJECTS =====
    match /projects/{projectId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== CLIENTS =====
    match /clients/{clientId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== WORKERS =====
    match /workers/{workerId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /{document=**} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    // ===== CANDIDATES =====
    match /candidates/{candidateId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /{document=**} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    // ===== BID INBOX =====
    match /bidInbox/{bidId} {
      allow read: if signedIn();

      allow create: if signedIn() && (
        isAdmin()
        || request.resource.data.createdByEmail == email()
        || request.resource.data.estimatorEmail == email()
      );

      allow update, delete: if signedIn() && (
        isAdmin()
        || resource.data.createdByEmail == email()
        || resource.data.estimatorEmail == email()
      );
    }

    // ===== BIDS =====
    match /bids/{bidId} {
      allow read: if signedIn();

      allow create: if signedIn() && (
        isAdmin()
        || request.resource.data.estimatorEmail == email()
      );

      allow update, delete: if isAdmin() || (
        signedIn()
        && resource.data.estimatorEmail == email()
      );

      match /{document=**} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || (
          signedIn()
          && get(/databases/$(database)/documents/bids/$(bidId)).data.estimatorEmail == email()
        );
      }
    }
  }
}