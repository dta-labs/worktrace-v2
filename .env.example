# Firebase Configuration
# Copia este archivo a .env.local y reemplaza los valores con tus credenciales reales
# NUNCA commits el archivo .env.local al repositorio

NG_APP_FIREBASE_API_KEY=tu_api_key_aqui
NG_APP_FIREBASE_AUTH_DOMAIN=tu_project_id.firebaseapp.com
NG_APP_FIREBASE_PROJECT_ID=tu_project_id
NG_APP_FIREBASE_STORAGE_BUCKET=tu_project_id.firebasestorage.app
NG_APP_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
NG_APP_FIREBASE_APP_ID=tu_app_id
NG_APP_FIREBASE_MEASUREMENT_ID=tu_measurement_id

# Database configuration
NG_APP_FIRESTORE_DATABASE=development
